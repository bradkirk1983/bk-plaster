rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'bpkirk1983@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'thumbnail', 'images', 'createdAt', 'ownerId'])
        && data.keys().size() == 6
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.thumbnail is string && data.thumbnail.size() > 0 && data.thumbnail.size() <= 2000
        && data.images is list && data.images.size() <= 50 && (data.images.size() == 0 || data.images[0] is string)
        && data.createdAt is number
        && data.ownerId == request.auth.uid;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProject(incoming()) && isValidId(projectId) && incoming().createdAt == request.time.toMillis();
      allow update: if isAdmin() && isValidProject(incoming()) && isValidId(projectId)
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'thumbnail', 'images']);
      allow delete: if isAdmin() && isValidId(projectId);
    }
    
    match /admins/{adminId} {
      allow read: if true;
    }
  }
}
